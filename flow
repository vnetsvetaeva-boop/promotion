<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<link href="https://fonts.googleapis.com/css2?family=Bai+Jamjuree:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:'Bai Jamjuree',sans-serif;background:#fff;color:#000;padding:20px 28px;line-height:1.5;max-width:100%;margin:0 auto}

.header{background:linear-gradient(135deg,#80EAFF 0%,#50D0ED 100%);border-radius:12px;padding:22px 26px 18px;margin-bottom:24px;position:relative;overflow:hidden}
.header::after{content:'';position:absolute;top:-30px;right:-20px;width:120px;height:120px;border-radius:50%;background:rgba(255,255,255,.12)}
.header-eyebrow{font-size:.75rem;font-weight:600;color:rgba(0,60,80,.5);text-transform:uppercase;letter-spacing:1.2px;margin-bottom:4px}
.header-title{font-size:28px;font-weight:700;color:#0A3D4F;line-height:1.2}
.header-sub{font-size:16px;color:rgba(0,60,80,.55);margin-top:6px}

.steps{display:flex;gap:0;margin-bottom:24px;padding:0 4px;flex-wrap:wrap}
.step{flex:1;min-width:80px;display:flex;flex-direction:column;align-items:center;position:relative;cursor:pointer;padding:10px 2px 12px;border-radius:10px;transition:background .15s}
.step:hover{background:rgba(0,0,0,.02)}
.step.active:hover{background:rgba(128,234,255,.08)}

.step:not(:last-child)::after{content:'';position:absolute;top:28px;left:calc(50% + 22px);width:calc(100% - 44px);height:2.5px;background:#ecedea;z-index:0}
.step.active:not(:last-child)::after{background:#80EAFF}

.step-circle{width:44px;height:44px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:18px;font-weight:700;position:relative;z-index:1;transition:all .25s}
.step-circle.off{background:#f4f4f3;color:#aaa;border:2px solid #ecedea}
.step-circle.on{background:#80EAFF;color:#0A3D4F;border:2.5px solid #50D0ED}
.step-circle.sel{box-shadow:0 0 0 5px rgba(128,234,255,.35);transform:scale(1.12)}

.step-label{font-size:14px;font-weight:600;color:#999;text-align:center;margin-top:8px;line-height:1.3}
.step.active .step-label{color:#000;font-weight:700}

.step-role{font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.4px;margin-top:4px;padding:3px 8px;border-radius:4px}
.role-you{background:#E0F7FF;color:#0E7490}
.role-hr{background:#f4f4f3;color:#999}
.role-both{background:#ECFDF5;color:#065F46}
.role-none{background:#f4f4f3;color:#bbb}

.detail{background:#f7f7f5;border-left:4px solid #80EAFF;padding:22px 26px;border-radius:0 10px 10px 0;margin-bottom:16px;animation:fadeSlide .25s ease}
@keyframes fadeSlide{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}

.detail-header{display:flex;align-items:center;gap:10px;margin-bottom:14px;flex-wrap:wrap}
.detail-num{width:32px;height:32px;border-radius:50%;background:#80EAFF;color:#0A3D4F;font-size:16px;font-weight:700;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.detail-title{font-size:22px;font-weight:700;color:#000}
.detail-badge{font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.3px;padding:4px 10px;border-radius:5px;margin-left:auto}

.detail-text{font-size:18px;font-weight:500;color:#333;line-height:1.6;margin-bottom:16px}

.your-role{background:#E0F7FF;border-radius:10px;padding:14px 18px;margin-bottom:14px}
.your-role-label{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.6px;color:#0E7490;margin-bottom:6px;display:flex;align-items:center;gap:6px}
.your-role-label::before{content:'👤';font-size:14px}
.your-role-text{font-size:16px;font-weight:500;color:#0A3D4F;line-height:1.55}

.callout-list{display:flex;flex-direction:column;gap:8px;margin-bottom:14px}
.callout-item{background:#fff;border:1px solid #ecedea;border-radius:10px;padding:12px 16px;font-size:15px;font-weight:500;color:#333;line-height:1.5;display:flex;gap:10px;align-items:flex-start}
.callout-icon{flex-shrink:0;width:24px;height:24px;display:flex;align-items:center;justify-content:center;font-size:14px;margin-top:1px}

.sla-bar{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:14px}
.sla-chip{background:#fff;border:1.5px solid #ecedea;border-radius:8px;padding:8px 14px;display:flex;align-items:center;gap:8px;font-size:14px;font-weight:600;color:#555}
.sla-chip .sla-icon{font-size:16px}

.tip-box{background:#FFFBEB;border:1px solid #FDE68A;border-radius:10px;padding:14px 18px;font-size:15px;font-weight:500;color:#92400E;line-height:1.5}
.tip-box strong{font-weight:700}
.tip-label{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:#B45309;margin-bottom:4px}

.nav-row{display:flex;gap:10px;margin-top:4px}
.nav-btn{flex:1;padding:14px;border-radius:10px;font-size:16px;font-weight:600;border:none;cursor:pointer;font-family:inherit;transition:all .15s}
.nav-prev{background:#f4f4f3;color:#555}
.nav-prev:hover{background:#ecedea}
.nav-next{background:linear-gradient(135deg,#80EAFF,#50D0ED);color:#0A3D4F}
.nav-next:hover{filter:brightness(.95)}
.nav-btn:disabled{opacity:.35;cursor:default;filter:none}
</style>
</head>
<body>

<div class="header">
  <div class="header-eyebrow">Promotion Process</div>
  <div class="header-title">From Opportunity to New Role</div>
  <div class="header-sub">Click any stage to see what happens, who owns it, and your role</div>
</div>

<div class="steps" id="steps"></div>
<div id="detail"></div>
<div class="nav-row">
  <button class="nav-btn nav-prev" id="prevBtn" onclick="go(-1)">← Previous</button>
  <button class="nav-btn nav-next" id="nextBtn" onclick="go(1)">Next →</button>
</div>

<script>
var STEPS=[
  {
    num:1,
    short:"Identify Opportunity",
    role:"hr",
    roleLabel:"HR + Leads",
    yourRole:null,
    title:"Identification of Opportunities",
    text:"HR and department leads review workforce planning and budget to determine where promotion opportunities exist.",
    bullets:[
      {icon:"📊",t:"Workforce planning review and budget analysis"},
      {icon:"🎯",t:"Determine which roles have promotion openings"},
      {icon:"📋",t:"Define criteria and expectations for each opportunity"}
    ],
    sla:[{icon:"⏱",t:"10 business days from cycle start"}],
    tip:null
  },
  {
    num:2,
    short:"Nominate",
    role:"you",
    roleLabel:"You",
    yourRole:"You identify the candidate and submit the nomination via HiBob.",
    title:"Nomination & Application",
    text:"Managers nominate candidates via HiBob. Employees can also self-nominate. The HiBob submission process is the same for promotions and raises — we'll walk through it step by step in the Raise Request lesson.",
    bullets:[
      {icon:"📝",t:"Submit nomination in HiBob within 5 business days of opportunity identification"},
      {icon:"✅",t:"Reference the eligibility checklist directly — if you can't tick every box, pause and address gaps first"},
    ],
    sla:[],
    tip:null
  },
  {
    num:3,
    short:"Assess",
    role:"both",
    roleLabel:"HR + You",
    yourRole:"You contribute performance insights and feedback. Have your data ready — you'll be consulted for performance context.",
    title:"Assessment & Evaluation",
    text:"Nominated candidates go through a structured evaluation combining data, reviews, and interviews.",
    bullets:[
      {icon:"📈",t:"KPI data pulled from Neo4j"},
      {icon:"📂",t:"Performance review history analyzed"},
      {icon:"🧪",t:"Skills assessments conducted"},
      {icon:"🗣",t:"Panel interviews (if applicable) and peer/manager feedback collected"}
    ],
    sla:[
      {icon:"⏱",t:"7 days — HR eligibility verification"},
      {icon:"⏱",t:"10–15 days — full assessment after verification"}
    ],
    tip:null
  },
  {
    num:4,
    short:"Approve",
    role:"none",
    roleLabel:"Dept Head + HR VP",
    yourRole:null,
    title:"Approval",
    text:"The approval chain follows a specific sequence. You are not directly involved at this stage.",
    bullets:[
      {icon:"1️⃣",t:"Department Head — confirms organizational need and candidate fit"},
      {icon:"2️⃣",t:"HR VP — reviews for policy compliance, pay equity, and budget alignment"}
    ],
    sla:[{icon:"⏱",t:"7 business days from evaluation completion"}],
    tip:null
  },
  {
    num:5,
    short:"Communicate",
    role:"hr",
    roleLabel:"HR",
    yourRole:null,
    title:"Communication",
    text:"HR issues a formal promotion letter covering the new role, responsibilities, and compensation. Payroll and HRIS records are updated.",
    bullets:[
      {icon:"✉️",t:"Formal promotion letter issued to the employee"},
      {icon:"💰",t:"Compensation adjustment takes effect in the next payroll cycle"},
      {icon:"🗂",t:"Payroll and HRIS records updated"}
    ],
    sla:[{icon:"⏱",t:"5 business days after approval"}],
    tip:null
  },
  {
    num:6,
    short:"Onboard into Role",
    role:"you",
    roleLabel:"You",
    yourRole:"You build and execute the transition plan. This is where your ownership returns in full.",
    title:"Onboarding into New Role",
    text:"The promotion isn't complete at the letter. A transition plan with clear goals must be prepared.",
    bullets:[
      {icon:"🎯",t:"Set clear goals and timelines for the first 30/60/90 days"},
      {icon:"📚",t:"Partner with L&D to arrange leadership training or upskilling"},
      {icon:"🤝",t:"Make sure the employee has resources and support to succeed in the new role"}
    ],
    sla:[{icon:"⏱",t:"10 business days from effective date"}],
    tip:null
  }
];

var sel=0;

function render(){
  var stepsEl=document.getElementById('steps');
  stepsEl.innerHTML=STEPS.map(function(s,i){
    var circCls='step-circle on';
    if(i===sel)circCls+=' sel';
    var roleCls=s.role==='you'?'role-you':s.role==='hr'?'role-hr':s.role==='both'?'role-both':'role-none';
    return '<div class="step active" data-idx="'+i+'">'+
      '<div class="'+circCls+'">'+s.num+'</div>'+
      '<div class="step-label">'+s.short+'</div>'+
      '<div class="step-role '+roleCls+'">'+s.roleLabel+'</div>'+
    '</div>';
  }).join('');

  stepsEl.querySelectorAll('.step').forEach(function(el){
    el.addEventListener('click',function(){
      sel=parseInt(el.dataset.idx);
      render();
    });
  });

  renderDetail();
  document.getElementById('prevBtn').disabled=sel===0;
  document.getElementById('nextBtn').disabled=sel===STEPS.length-1;
}

function renderDetail(){
  var s=STEPS[sel];
  var badgeCls=s.role==='you'?'role-you':s.role==='hr'?'role-hr':s.role==='both'?'role-both':'role-none';
  var html='<div class="detail" key="'+sel+'">'+
    '<div class="detail-header">'+
      '<div class="detail-num">'+s.num+'</div>'+
      '<div class="detail-title">'+s.title+'</div>'+
      '<div class="detail-badge '+badgeCls+'">'+s.roleLabel+'</div>'+
    '</div>'+
    '<div class="detail-text">'+s.text+'</div>';

  if(s.yourRole){
    html+='<div class="your-role">'+
      '<div class="your-role-label">Your role as a manager</div>'+
      '<div class="your-role-text">'+s.yourRole+'</div>'+
    '</div>';
  }

  if(s.bullets&&s.bullets.length){
    html+='<div class="callout-list">';
    s.bullets.forEach(function(b){
      html+='<div class="callout-item"><div class="callout-icon">'+b.icon+'</div><div>'+b.t+'</div></div>';
    });
    html+='</div>';
  }

  if(s.sla&&s.sla.length){
    html+='<div class="sla-bar">';
    s.sla.forEach(function(sl){
      html+='<div class="sla-chip"><span class="sla-icon">'+sl.icon+'</span>'+sl.t+'</div>';
    });
    html+='</div>';
  }

  if(s.tip){
    html+='<div class="tip-box"><div class="tip-label">💡 Keep in mind</div>'+s.tip+'</div>';
  }

  html+='</div>';
  document.getElementById('detail').innerHTML=html;
}

function go(dir){
  var next=sel+dir;
  if(next>=0&&next<STEPS.length){
    sel=next;
    render();
  }
}

render();
</script>
</body>
</html>
